generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model academic_years {
  id                    Int                     @id @default(autoincrement())
  year_name             String                  @unique @db.VarChar(20)
  start_date            DateTime?               @db.Date
  end_date              DateTime?               @db.Date
  is_active             Boolean?                @default(false)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  classroom_assignments classroom_assignments[]
  projects              projects[]
  semesters             semesters[]
  students              students[]

  @@unique([id, year_name], map: "academic_year_name_unique")
}

model assessment_items {
  id                Int              @id @default(autoincrement())
  grade_category_id Int
  name              String           @db.VarChar(255)
  max_score         Decimal          @db.Decimal(5, 2)
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  grade_categories  grade_categories @relation(fields: [grade_category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_scores    student_scores[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance_records {
  id                Int                @id @default(autoincrement())
  student_id        Int?
  check_date        DateTime           @db.Date
  check_time        DateTime?          @db.Time(6)
  status_id         Int?
  remark            String?            @db.VarChar(255)
  attendance_status attendance_status? @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students          students?          @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([student_id, check_date])
}

model audit_logs {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  action     String    @db.VarChar(100)
  table_name String    @db.VarChar(100)
  record_id  Int?
  old_data   Json?
  new_data   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model budget_types {
  id         Int        @id @default(autoincrement())
  name       String     @unique(map: "budget_types_name_unique") @db.VarChar(255)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  projects   projects[]
}

model buildings {
  id            Int     @id @default(autoincrement())
  building_name String  @unique @db.VarChar(100)
  total_floors  Int?
  rooms         rooms[]
}

model classroom_students {
  id               Int        @id @default(autoincrement())
  classroom_id     Int
  student_id       Int
  academic_year_id Int
  roll_number      Int?
  classrooms       classrooms @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  students         students   @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([classroom_id, student_id, academic_year_id], map: "classroom_students_classroom_id_student_id_academic_year_key")
}

model classrooms {
  id                    Int                     @id @default(autoincrement())
  room_name             String                  @db.VarChar(50)
  capacity              Int?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  grade_level_id        Int                     @unique(map: "classrooms_unique_1")
  class_schedule        class_schedule[]
  classroom_assignments classroom_assignments[]
  classroom_students    classroom_students[]
  levels                grade_level             @relation(fields: [grade_level_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_grade_level_idalter")
}

model day_of_weeks {
  id             Int              @id
  day_name_th    String           @db.VarChar(20)
  day_name_en    String           @db.VarChar(20)
  short_name     String           @db.VarChar(10)
  color_code     String?          @db.VarChar(7)
  class_schedule class_schedule[]
}

model departments {
  id              Int        @id @default(autoincrement())
  department_name String     @unique @db.VarChar(100)
  events          events[]
  projects        projects[]
  teachers        teachers[]
}

model employment_types {
  id        Int        @id @default(autoincrement())
  type_name String     @db.VarChar(100)
  teachers  teachers[]
}

model evaluation_types {
  id                 Int                  @id @default(autoincrement())
  evaluation_name    String               @db.VarChar(100)
  grade_scale_groups grade_scale_groups[]
  subject_categories subject_categories[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model event_targets {
  id           Int          @id @default(autoincrement())
  event_id     Int
  target_type  String       @db.VarChar(30)
  target_value String?      @db.VarChar(255)
  events       events       @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  target_types target_types @relation(fields: [target_type], references: [code], onDelete: NoAction, map: "fk_target_type_code")
}

model event_types {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  color_code String?   @db.VarChar(7)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  events     events[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model events {
  id             Int                @id @default(autoincrement())
  title          String             @db.VarChar(200)
  description    String?
  start_datetime DateTime           @db.Timestamp(6)
  end_datetime   DateTime           @db.Timestamp(6)
  is_all_day     Boolean?           @default(false)
  location       String?            @db.VarChar(200)
  created_by     Int?
  visibility     String             @db.VarChar(20)
  created_at     DateTime?          @default(now()) @db.Timestamp(6)
  teacher_id     Int?
  event_type_id  Int?
  department_id  Int?
  semester_id    Int?
  status         enum_event_status?
  event_targets  event_targets[]
  semesters      semesters?         @relation(fields: [semester_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "event_semester_id_fkey")
  users          users?             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments    departments?       @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  event_types    event_types?       @relation(fields: [event_type_id], references: [id], onUpdate: NoAction)
  teachers       teachers?          @relation(fields: [teacher_id], references: [id], onUpdate: NoAction)
}

model expense_categories {
  id               Int                @id @default(autoincrement())
  name             String             @unique(map: "expense_categories_name_unique") @db.VarChar(255)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  project_expenses project_expenses[]
  project_budgets  project_budgets[]
}

model final_grades {
  id             Int           @id @default(autoincrement())
  total_score    Decimal       @db.Decimal(6, 2)
  letter_grade   String?       @db.VarChar(10)
  grade_point    Decimal?      @db.Decimal(3, 2)
  is_locked      Boolean?      @default(false)
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  grade_scale_id Int?
  student_id     Int?
  subject_id     Int?
  semester_id    Int?
  calculated_by  Int?
  calculated_at  DateTime?     @default(now()) @db.Timestamp(6)
  semesters      semesters?    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_final_grade_semester")
  subjects       subjects?     @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_final_grade_subject")
  teachers       teachers?     @relation(fields: [calculated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_final_grades_calculated_by_teacher")
  students       students?     @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_final_grades_student")
  grade_scales   grade_scales? @relation(fields: [grade_scale_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "grade_scale_id")

  @@unique([student_id, subject_id, semester_id])
}

model fitness_test_criteria {
  id                Int       @id @default(autoincrement())
  test_name         String    @db.VarChar(255)
  unit              String    @db.VarChar(50)
  passing_threshold Decimal   @db.Decimal
  comparison_type   String?   @default(">=") @db.VarChar(10)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  academic_year     Int?
  gender            String?   @db.VarChar(20)
  grade_level       String?   @db.VarChar(100)
}

model genders {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(50)
  students students[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model grade_categories {
  id                      Int                   @id @default(autoincrement())
  classroom_assignment_id Int
  weight_percent          Decimal               @db.Decimal(5, 2)
  created_at              DateTime?             @default(now()) @db.Timestamp(6)
  category_type_id        Int?
  name                    String                @default("Category") @db.VarChar(100)
  assessment_items        assessment_items[]
  grade_category_types    grade_category_types? @relation(fields: [category_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classroom_assignments   classroom_assignments @relation(fields: [classroom_assignment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "grade_categories_teaching_assignment_id_fkey")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model grade_scales {
  id                   Int                 @id @default(autoincrement())
  min_score            Decimal             @db.Decimal(5, 2)
  max_score            Decimal             @db.Decimal(5, 2)
  letter_grade         String              @db.VarChar(5)
  grade_point          Decimal             @db.Decimal(3, 2)
  grade_scale_group_id Int?
  final_grades         final_grades[]
  grade_scale_groups   grade_scale_groups? @relation(fields: [grade_scale_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model grade_scale_groups {
  id                 Int               @id @default(autoincrement())
  name               String            @db.VarChar(100)
  is_default         Boolean?          @default(false)
  description        String?
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  evaluation_type_id Int?
  evaluation_types   evaluation_types? @relation(fields: [evaluation_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_grade_scale_group_evaluation")
  grade_scales       grade_scales[]
  subjects           subjects[]
}

model health_checkup_records {
  id            Int       @id @default(autoincrement())
  student_id    Int
  semester_id   Int?
  checkup_date  DateTime  @db.Date
  weight        Decimal?  @db.Decimal(5, 2)
  height        Decimal?  @db.Decimal(5, 2)
  bmi           Decimal?  @db.Decimal(4, 2)
  vision_left   String?   @db.VarChar(20)
  vision_right  String?   @db.VarChar(20)
  dental_status String?   @db.VarChar(100)
  doctor_note   String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  users         users     @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model learning_subject_groups {
  id         Int        @id @default(autoincrement())
  group_name String     @unique(map: "learning_subject_groups_name_key") @db.VarChar(100)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  subjects   subjects[]
}

model name_prefixes {
  id          Int        @id @default(autoincrement())
  prefix_name String     @unique @db.VarChar(50)
  students    students[]
  teachers    teachers[]
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(150)
  message    String
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model periods {
  id             Int              @id
  start_time     DateTime?        @db.Time(6)
  end_time       DateTime?        @db.Time(6)
  period_name    String?          @db.VarChar
  class_schedule class_schedule[]
}

model project_expenses {
  id                  Int                  @id @default(autoincrement())
  project_id          Int
  expense_date        DateTime             @db.Date
  title               String               @db.VarChar(255)
  amount              Decimal              @db.Decimal(12, 2)
  receipt_number      String?              @db.VarChar(100)
  recorded_by         Int?
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  expense_category_id Int?
  semester_id         Int?
  payment_method      enum_peyment_method?
  receipt_file        String?              @db.VarChar(255)
  updated_at          DateTime?            @db.Timestamp(6)
  note                String?
  vendor_name         String?              @db.VarChar(255)
  disbursement_number String?              @db.VarChar(100)
  status              String               @default("PENDING") @db.VarChar(30)
  approved_by         Int?
  approved_at         DateTime?            @db.Timestamp(6)
  rejection_reason    String?
  semesters           semesters?           @relation(fields: [semester_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_project_expenses_semester")
  users               users?               @relation(fields: [recorded_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_project_expenses_user")
  expense_categories  expense_categories?  @relation(fields: [expense_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects            projects             @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model project_types {
  id          Int        @id @default(autoincrement())
  name        String     @unique(map: "project_types_name_unique") @db.VarChar(150)
  description String?
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  projects    projects[]
}

model projects {
  id               Int                @id @default(autoincrement())
  project_code     String?            @unique @db.VarChar(50)
  project_name     String             @db.VarChar(255)
  description      String?
  teacher_id       Int?
  start_date       DateTime?          @db.Date
  end_date         DateTime?          @db.Date
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  department_id    Int?
  budget_type_id   Int?
  allocated_budget Decimal            @default(0.00) @db.Decimal(12, 2)
  project_type_id  Int?
  academic_year_id Int?
  status              String               @default("PLANNING") @db.VarChar(30)
  rationale           String?
  expected_outcomes   String?
  target_participants Int?
  created_by          Int?
  submitted_by        Int?
  approved_by         Int?
  submitted_at        DateTime?            @db.Timestamp(6)
  approved_at         DateTime?            @db.Timestamp(6)
  rejection_reason    String?
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)
  project_expenses project_expenses[]
  project_objectives project_objectives[]
  project_indicators project_indicators[]
  project_activities project_activities[]
  project_budgets    project_budgets[]
  project_approvals  project_approvals[]
  project_documents  project_documents[]
  academic_years   academic_years?    @relation(fields: [academic_year_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  budget_types     budget_types?      @relation(fields: [budget_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "projects_budget_id_fkey")
  departments      departments?       @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_types    project_types?     @relation(fields: [project_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers         teachers?          @relation(fields: [teacher_id], references: [id], onUpdate: NoAction)
}

model project_objectives {
  id             Int       @id @default(autoincrement())
  project_id     Int
  objective_text String
  order_number   Int       @default(1)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  projects       projects  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model project_indicators {
  id             Int       @id @default(autoincrement())
  project_id     Int
  indicator_name String    @db.VarChar(255)
  target_value   String?   @db.VarChar(100)
  actual_value   String?   @db.VarChar(100)
  unit           String?   @db.VarChar(50)
  result_note    String?
  order_number   Int       @default(1)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  projects       projects  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model project_activities {
  id                     Int       @id @default(autoincrement())
  project_id             Int
  activity_name          String    @db.VarChar(255)
  description            String?
  responsible_teacher_id Int?
  start_date             DateTime? @db.Date
  end_date               DateTime? @db.Date
  planned_budget         Decimal   @default(0) @db.Decimal(12, 2)
  status                 String    @default("PLANNING") @db.VarChar(30)
  order_number           Int       @default(1)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  updated_at             DateTime? @default(now()) @db.Timestamp(6)
  projects               projects  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  teachers               teachers? @relation(fields: [responsible_teacher_id], references: [id], onDelete: SetNull)
}

model project_budgets {
  id                  Int                 @id @default(autoincrement())
  project_id          Int
  semester_id         Int
  expense_category_id Int?
  planned_amount      Decimal             @default(0) @db.Decimal(12, 2)
  note                String?
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  projects            projects            @relation(fields: [project_id], references: [id], onDelete: Cascade)
  semesters           semesters           @relation(fields: [semester_id], references: [id], onDelete: Restrict)
  expense_categories  expense_categories? @relation(fields: [expense_category_id], references: [id], onDelete: SetNull)

  @@unique([project_id, semester_id, expense_category_id], map: "project_budgets_unique_plan")
}

model project_approvals {
  id         Int       @id @default(autoincrement())
  project_id Int
  action     String    @db.VarChar(30)
  action_by  Int?
  note       String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  projects   projects  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model project_documents {
  id            Int       @id @default(autoincrement())
  project_id    Int
  document_type String    @default("OTHER") @db.VarChar(50)
  file_name     String    @db.VarChar(255)
  file_path     String    @db.VarChar(500)
  mime_type     String?   @db.VarChar(100)
  file_size     Int?
  uploaded_by   Int?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  projects      projects  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model roles {
  id                    Int                     @id @default(autoincrement())
  role_name             String                  @unique(map: "roles_name_key") @db.VarChar(50)
  description           String?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  evaluation_categories evaluation_categories[]
  users                 users[]
}

model rooms {
  id          Int        @id
  room_name   String?    @db.VarChar(50)
  capacity    Int?
  floor       Int?
  building_id Int?
  buildings   buildings? @relation(fields: [building_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([room_name, building_id], map: "rooms_name_building_unique")
}

model semesters {
  id                           Int                            @id @default(autoincrement())
  academic_year_id             Int
  semester_number              Int
  start_date                   DateTime?                      @db.Date
  end_date                     DateTime?                      @db.Date
  is_active                    Boolean?                       @default(false)
  created_at                   DateTime?                      @default(now()) @db.Timestamp(6)
  behavior_records             behavior_records[]
  class_schedule               class_schedule[]
  evaluation_responses         evaluation_responses[]
  evaluation_schedules         evaluation_schedules[]
  events                       events[]
  final_grades                 final_grades[]
  project_expenses             project_expenses[]
  project_budgets              project_budgets[]
  academic_years               academic_years                 @relation(fields: [academic_year_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_daily_health_records student_daily_health_records[]

  @@unique([academic_year_id, semester_number])
}

model student_scores {
  id                 Int              @id @default(autoincrement())
  assessment_item_id Int
  score              Decimal?         @default(0.00) @db.Decimal(5, 2)
  is_missing         Boolean?         @default(false)
  remark             String?
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  updated_at         DateTime?        @default(now()) @db.Timestamp(6)
  is_passed          Boolean?
  student_id         Int?
  students           students?        @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_student_scores_student")
  assessment_items   assessment_items @relation(fields: [assessment_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([student_id, assessment_item_id])
}

model student_statuses {
  id          Int                  @id @default(autoincrement())
  status_name enum_student_status?
  students    students[]
}

model students {
  id                           Int                            @id
  user_id                      Int                            @unique
  student_code                 String                         @unique @db.VarChar(20)
  first_name                   String                         @db.VarChar(100)
  last_name                    String                         @db.VarChar(100)
  date_of_birth                DateTime?                      @db.Date
  phone                        String?                        @db.VarChar(20)
  address                      String?
  created_at                   DateTime?                      @default(now()) @db.Timestamp(6)
  updated_at                   DateTime?                      @default(now()) @db.Timestamp(6)
  prefix_id                    Int?
  status_id                    Int?
  gender_id                    Int?
  enrollment_date              DateTime?                      @db.Date
  admission_year_id            Int?
  student_national_id          String?                        @unique(map: "students_national_id_unique") @db.VarChar(13)
  parent_name                  String?                        @db.VarChar(150)
  parent_phone                 String?                        @db.VarChar(20)
  attendance_records           attendance_records[]
  behavior_records             behavior_records[]
  classroom_students           classroom_students[]
  final_grades                 final_grades[]
  student_daily_health_records student_daily_health_records[]
  student_scores               student_scores[]
  academic_years               academic_years?                @relation(fields: [admission_year_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_student_admission_year_id_year")
  genders                      genders?                       @relation(fields: [gender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name_prefixes                name_prefixes?                 @relation(fields: [prefix_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student_statuses             student_statuses?              @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                        users                          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model subject_categories {
  id                 Int               @id @default(autoincrement())
  category_name      String            @unique @db.VarChar(100)
  description        String?
  evaluation_type_id Int?              @default(1)
  evaluation_types   evaluation_types? @relation(fields: [evaluation_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subject_category_evaluations")
  subjects           subjects[]
}

model subjects {
  id                        Int                      @id
  subject_code              String                   @unique @db.VarChar(20)
  subject_name              String                   @db.VarChar(150)
  credit                    Decimal?                 @default(1.0) @db.Decimal(3, 1)
  created_at                DateTime?                @default(now()) @db.Timestamp(6)
  learning_subject_group_id Int?
